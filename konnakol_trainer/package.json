{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=127.0.0.1 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "ui:guard": "node scripts/ui-geometry-guard.mjs",
    "ui:guard:staged": "node scripts/ui-geometry-guard.mjs --staged",
    "macro": "npm run macro:progressive-logs",
    "macro:progressive-logs": "tsx scripts/run-progressive-log-macro.ts",
    "macro:evaluate": "tsx scripts/evaluate-macro-results.ts",
    "regression:odd-jati": "tsx scripts/run-odd-jati-regression.ts",
    "decode:snapshot-timing": "tsx scripts/decode-snapshot-timing.ts",
    "roundtrip:build": "esbuild scripts/snapshot-roundtrip-loop.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/roundtrip.js",
    "roundtrip": "node dist/roundtrip.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "midi-writer-js": "^3.2.1",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
